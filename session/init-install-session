#!/bin/bash

set -euo pipefail

tty="${1:-${XDG_VTNR:-}}"
profile_file="${XDG_CONFIG_HOME:-$HOME/.config}/init-install/tty-profiles.conf"

if [ -z "$tty" ]; then
    exit 0
fi

case "$tty" in
    *[!0-9]*)
        echo "TTY inválido: $tty" >&2
        exit 0
        ;;
esac

if [ ! -f "$profile_file" ]; then
    exit 0
fi

# El archivo lo genera install_session_profiles.sh con asignaciones simples TTYn_DESKTOP/TTYn_BAR.
# shellcheck disable=SC1090
source "$profile_file"

desktop_var="TTY${tty}_DESKTOP"
bar_var="TTY${tty}_BAR"
desktop="${!desktop_var:-none}"
bar="${!bar_var:-none}"

export INIT_INSTALL_TTY="$tty"
export INIT_INSTALL_DESKTOP="$desktop"
export INIT_INSTALL_BAR="$bar"

case "$desktop" in
    hyprland)
        if command -v start-hyprland >/dev/null 2>&1; then
            exec start-hyprland
        fi
        exec Hyprland
        ;;
    mango)
        exec mango
        ;;
    none|"")
        exit 0
        ;;
    *)
        echo "Desktop desconocido para TTY$tty: $desktop" >&2
        exit 1
        ;;
esac
