#!/bin/bash

set -euo pipefail

profile_file="${XDG_CONFIG_HOME:-$HOME/.config}/init-install/tty-profiles.conf"
bar="${INIT_INSTALL_BAR:-}"
tty="${INIT_INSTALL_TTY:-${XDG_VTNR:-}}"

if [ -z "$bar" ] && [ -n "$tty" ] && [ -f "$profile_file" ]; then
    # shellcheck disable=SC1090
    source "$profile_file"
    bar_var="TTY${tty}_BAR"
    bar="${!bar_var:-none}"
fi

case "$bar" in
    waybar)
        if command -v waybar >/dev/null 2>&1; then
            waybar &
        else
            echo "waybar no está instalado" >&2
        fi
        ;;
    noctalia)
        if command -v qs >/dev/null 2>&1; then
            qs -c noctalia-shell &
        else
            echo "Noctalia Shell no está instalado" >&2
        fi
        ;;
    none|"")
        ;;
    *)
        echo "Barra desconocida: $bar" >&2
        ;;
esac
