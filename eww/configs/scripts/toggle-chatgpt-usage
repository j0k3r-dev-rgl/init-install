#!/usr/bin/env bash
set -euo pipefail

notify_missing() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send \
      --app-name="Hyprland" \
      --urgency=normal \
      --icon=dialog-information \
      "Cuota ChatGPT" \
      "Eww no está instalado. Instálalo con: yay -S eww"
  fi
}

notify_error() {
  local message="$1"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send \
      --app-name="Hyprland" \
      --urgency=critical \
      --icon=dialog-error \
      "Cuota ChatGPT" \
      "$message"
  fi
}

if ! command -v eww >/dev/null 2>&1; then
  notify_missing
  exit 127
fi

if [[ ! -f "$HOME/.config/eww/eww.yuck" ]]; then
  notify_error "No encuentro ~/.config/eww/eww.yuck"
  exit 1
fi

if [[ ! -r "$HOME/.pi/agent/auth.json" ]]; then
  notify_error "No encuentro el auth de Pi en ~/.pi/agent/auth.json"
  exit 1
fi

eww --config "$HOME/.config/eww" daemon >/dev/null 2>&1 || true
sleep 0.15

if ! eww --config "$HOME/.config/eww" open --toggle chatgpt-usage; then
  notify_error "No pude mostrar/ocultar el panel. Revisa la configuración de Eww."
  exit 1
fi
