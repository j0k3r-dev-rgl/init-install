#!/usr/bin/env bash
set -euo pipefail

notify_error() {
  local message="$1"
  if command -v notify-send >/dev/null 2>&1; then
    notify-send \
      --app-name="Hyprland" \
      --urgency=critical \
      --icon=dialog-error \
      "Atajos de teclado" \
      "$message"
  fi
}

if ! command -v eww >/dev/null 2>&1; then
  notify_error "Eww no está instalado. Instálalo con: yay -S eww"
  exit 127
fi

if [[ ! -f "$HOME/.config/eww/eww.yuck" ]]; then
  notify_error "No encuentro ~/.config/eww/eww.yuck"
  exit 1
fi

eww --config "$HOME/.config/eww" daemon >/dev/null 2>&1 || true
sleep 0.15

if ! eww --config "$HOME/.config/eww" open --toggle keybinds-cheatsheet; then
  notify_error "No pude mostrar/ocultar los atajos. Revisa la configuración de Eww."
  exit 1
fi
