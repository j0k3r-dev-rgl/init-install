{
	"$schema": "https://opencode.ai/config.json",
	"mcp": {
		"context7": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true,
			"headers": {
				"CONTEXT7_API_KEY": "REPLACE_ME"
			}
		}
	},
	"plugin": ["opencode-anthropic-login-via-cli@latest"],
	"instructions": ["$HOME/.config/opencode/rules/*.md"]
}
