{
    "label" : "logout",
    "action" : "hyprctl dispatch exit 0",
    "text" : "Cerrar sesion",
    "keybind" : "e"
}
{
    "label" : "suspend",
    "action" : "systemctl suspend",
    "text" : "Suspender",
    "keybind" : "u"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "text" : "Apagar",
    "keybind" : "s"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "text" : "Reiniciar",
    "keybind" : "r"
}
